# Node diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Test / coverage ───────────────────────────────────────────────────────────
coverage/
coverage
.nyc_output/
.nyc_output
*.lcov

# ── Allure (if enabled later) ────────────────────────────────────────────────
